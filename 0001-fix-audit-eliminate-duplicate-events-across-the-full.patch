+def _merge_rows_by_event_id(rows: List[Dict], table_id: str) -> int:
+    """
+    Insert rows using BigQuery MERGE so rows with a known event_id are never duplicated.
+    Uses a VALUES clause built from the batch — no temp table needed for small batches.
+    Falls back to streaming insert for batches > 500 rows (MERGE SQL size limit).
+    Returns the number of rows inserted.
+    """
+    MERGE_BATCH_LIMIT = 500
+
+    # For large batches, chunk and recurse
+    if len(rows) > MERGE_BATCH_LIMIT:
+        total = 0
+        for i in range(0, len(rows), MERGE_BATCH_LIMIT):
+            total += _merge_rows_by_event_id(rows[i:i + MERGE_BATCH_LIMIT], table_id)
+        return total
+
+    # Build MERGE SQL with inline VALUES
+    # Each row becomes: ('event_id', TIMESTAMP('ts'), 'event', 'hook', ...)
+    def _escape(s: str) -> str:
+        """Escape a string for safe inclusion in BigQuery SQL literals."""
+        return s.replace("\\", "\\\\").replace("'", "\\'")
+
+    value_rows = []
+    for r in rows:
+        value_rows.append(
+            f"('{_escape(r['event_id'])}', "
+            f"TIMESTAMP('{_escape(r['ts'])}'), "
+            f"'{_escape(r['event'])}', "
+            f"'{_escape(r['hook'])}', "
+            f"'{_escape(r['tool'])}', "
+            f"'{_escape(r['result'])}', "
+            f"'{_escape(r['reason'])}', "
+            f"'{_escape(r['project'])}')"
+        )
+
+    values_sql = ",\n  ".join(value_rows)
+
+    sql = f"""
+        MERGE `{table_id}` AS T
+        USING (
+          SELECT * FROM UNNEST([
+            STRUCT<event_id STRING, ts TIMESTAMP, event STRING, hook STRING,
+                   tool STRING, result STRING, reason STRING, project STRING>
+            {values_sql}
+          ])
+        ) AS S ON T.event_id = S.event_id
+        WHEN NOT MATCHED THEN
+          INSERT (event_id, ts, event, hook, tool, result, reason, project)
+          VALUES (S.event_id, S.ts, S.event, S.hook, S.tool, S.result, S.reason, S.project)
+    """
+
+    try:
+        job = bigquery_client.query(sql)
+        job.result(timeout=60)
+        num_inserted = job.num_dml_affected_rows or 0
+        logger.info(f"MERGE inserted {num_inserted}/{len(rows)} rows (skipped {len(rows) - num_inserted} duplicates)")
+        return num_inserted
+    except Exception as e:
+        logger.error(f"MERGE failed, falling back to streaming insert: {e}")
+        # Fallback: streaming insert (may re-introduce duplicates, but better than data loss)
+        errors = bigquery_client.insert_rows_json(table_id, rows, timeout=30)
+        if errors:
+            logger.error(f"Fallback streaming insert errors: {errors}")
+            return 0
+        return len(rows)
 
 
 def load_audit_from_gcs(event, context):
@@ -289,16 +392,44 @@ def _run_query(sql: str, params=None) -> list:
     return [dict(row) for row in result]
 
 
+def _dedup_cte(ref: str, period: int) -> str:
+    """
+    Returns a WITH clause that deduplicates rows by event_id.
+
+    Strategy:
+    - Rows WITH event_id: keep only one row per event_id (pick the earliest ts).
+      This handles any duplicates that slipped past the MERGE (e.g. legacy rows
+      re-ingested before P3 was deployed, or rows from the bq CLI load path).
+    - Rows WITHOUT event_id (legacy): kept as-is — no dedup possible.
+
+    Usage: prefix your query with _dedup_cte(ref, period) and query `deduped` instead
+    of the raw table.
+    """
+    return f"""
+        WITH deduped AS (
+          SELECT
+            event_id, ts, event, hook, tool, result, reason, project,
+            ROW_NUMBER() OVER (
+              PARTITION BY COALESCE(NULLIF(event_id, ''), CAST(ts AS STRING) || hook || tool || result)
+              ORDER BY ts ASC
+            ) AS _rn
+          FROM {ref}
+          WHERE ts >= TIMESTAMP_SUB(CURRENT_TIMESTAMP(), INTERVAL {period} DAY)
+        )
+    """
+
+
 def _query_stats(period: int) -> list:
     ref = _get_table_ref(TABLE_ID)
     sql = f"""
