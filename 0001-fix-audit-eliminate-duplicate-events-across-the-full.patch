index 812958f..7459d93 100755
--- a/bin/hapai
+++ b/bin/hapai
@@ -885,38 +885,81 @@ cmd_sync() {
     return 0
   fi
 
-  # Prepare destination path: gs://bucket/YYYY-MM/DD.jsonl
+  # ── Incremental sync: only upload lines after the last synced cursor ──────
+  # Cursor file stores the line count that was last successfully uploaded.
+  # On each sync, we extract only new lines → upload a delta file → update cursor.
+  # This prevents re-inserting every row on every run (the original duplication bug).
+  local cursor_file="${HAPAI_HOME}/state/sync_cursor"
+  local last_line=0
+  if [[ -f "$cursor_file" ]]; then
+    last_line="$(cat "$cursor_file" 2>/dev/null | tr -d '[:space:]')"
+    [[ ! "$last_line" =~ ^[0-9]+$ ]] && last_line=0
+  fi
+
+  local total_lines
+  total_lines="$(wc -l < "$audit_file" | tr -d '[:space:]')"
+
+  if [[ "$total_lines" -le "$last_line" ]]; then
+    log_info "No new audit entries since last sync (cursor: $last_line, total: $total_lines)"
+    return 0
+  fi
+
+  local new_lines=$(( total_lines - last_line ))
+  log_info "Found $new_lines new entries (cursor: $last_line → $total_lines)"
+
+  # Extract only the new lines into a temp delta file
+  local delta_file
+  delta_file="$(mktemp "${HAPAI_HOME}/sync_delta_XXXXXX.jsonl")"
+  tail -n "+$(( last_line + 1 ))" "$audit_file" > "$delta_file"
+
+  if [[ ! -s "$delta_file" ]]; then
+    rm -f "$delta_file"
+    log_info "Delta file is empty — nothing to sync"
+    return 0
+  fi
+
+  # Prepare destination path: gs://bucket/YYYY-MM/DD-<cursor>.jsonl
+  # Including the cursor offset in the filename makes each upload idempotent:
+  # re-running sync with the same cursor writes to the same GCS object (overwrite = safe).
   local now date_part day_part gcs_path
   now="$(date -u +%Y-%m-%d)"
   date_part="${now:0:7}"  # YYYY-MM
   day_part="${now:8:2}"   # DD
-  gcs_path="gs://${bucket}/${date_part}/${day_part}.jsonl"
+  gcs_path="gs://${bucket}/${date_part}/${day_part}-${last_line}.jsonl"
 
-  log_info "Syncing audit log to Cloud Storage..."
-  log_info "Source: $audit_file"
+  log_info "Syncing ${new_lines} new audit entries to Cloud Storage..."
+  log_info "Source: $delta_file (delta from line $last_line)"
   log_info "Destination: $gcs_path"
 
   if [[ "$dry_run" == "true" ]]; then
-    log_info "[DRY-RUN] Would sync to $gcs_path"
+    log_info "[DRY-RUN] Would sync $new_lines lines to $gcs_path"
+    rm -f "$delta_file"
     return 0
   fi
 
   # Check if gsutil is available
   if ! command -v gsutil &>/dev/null; then
+    rm -f "$delta_file"
     log_error "gsutil is required but not installed"
     log_info "Install Google Cloud SDK: https://cloud.google.com/sdk/docs/install"
     exit 1
   fi
 
-  # Upload to Cloud Storage
-  if gsutil -m cp "$audit_file" "$gcs_path" 2>&1; then
+  # Upload delta to Cloud Storage
+  if gsutil -m cp "$delta_file" "$gcs_path" 2>&1; then
     log_ok "Sync completed successfully"
-    log_info "Uploaded to $gcs_path"
+    log_info "Uploaded $new_lines lines to $gcs_path"
+    # Update cursor only after successful upload
+    echo "$total_lines" > "$cursor_file"
+    log_info "Cursor updated: $last_line → $total_lines"
   else
+    rm -f "$delta_file"
