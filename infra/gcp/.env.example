# hapai Cloud Dashboard — Environment Variables
# Copy this to .env and fill in your values
# IMPORTANT: Never commit .env with real credentials!

# Google Cloud Project Configuration
GCP_PROJECT_ID=hapai-oute

# Service Account Credentials (path to JSON key file)
# Download from: GCP Console → Service Accounts → hapai-sync → Keys
GOOGLE_APPLICATION_CREDENTIALS=~/.config/gcp-sa-key.json

# Cloud Storage Bucket Name
GCP_BUCKET_NAME=hapai-audit-$(whoami)

# Google OAuth2 Dashboard Credentials
# Create at: GCP Console → APIs & Services → Credentials
# Choose: OAuth 2.0 Client ID (Web application)
GOOGLE_OAUTH_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID_HERE

# Dashboard URL (custom domain)
DASHBOARD_URL=https://hapai.oute.pro

# BigQuery Dataset and Table
BIGQUERY_DATASET=hapai_dataset
BIGQUERY_TABLE=events

# Data Retention (days)
DATA_RETENTION_DAYS=90
