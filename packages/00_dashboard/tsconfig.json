{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": ".svelte-kit/output",
    "rootDir": "src",
    "paths": {
      "$lib": ["src/lib"],
      "$lib/*": ["src/lib/*"],
      "@hapai/design-system": ["../../packages/design-system/src"],
      "@hapai/design-system/*": ["../../packages/design-system/src/*"],
      "@hapai/shared": ["../../shared"],
      "@hapai/shared/*": ["../../shared/*"]
    }
  },
  "include": ["src"]
}
