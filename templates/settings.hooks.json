{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash __HAPAI_HOOKS__/pre-tool-use/flow-dispatcher.sh",
            "timeout": 7
          },
          {
            "type": "command",
            "command": "bash __HAPAI_HOOKS__/pre-tool-use/guard-branch.sh",
            "timeout": 7,
            "if": "Bash(git *)"
          },
          {
            "type": "command",
            "command": "bash __HAPAI_HOOKS__/pre-tool-use/guard-commit-msg.sh",
            "timeout": 7,
            "if": "Bash(git commit*)"
          },
          {
            "type": "command",
            "command": "bash __HAPAI_HOOKS__/pre-tool-use/guard-destructive.sh",
            "timeout": 7
          },
          {
            "type": "command",
            "command": "bash __HAPAI_HOOKS__/pre-tool-use/guard-blast-radius.sh",
            "timeout": 7,
            "if": "Bash(git commit*)"
          },
          {
            "type": "command",
            "command": "bash __HAPAI_HOOKS__/pre-tool-use/guard-pr-review.sh",
            "timeout": 7
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash __HAPAI_HOOKS__/pre-tool-use/guard-files.sh",
            "timeout": 7
          },
          {
            "type": "command",
            "command": "bash __HAPAI_HOOKS__/pre-tool-use/guard-uncommitted.sh",
            "timeout": 7
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash __HAPAI_HOOKS__/post-tool-use/auto-format.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash __HAPAI_HOOKS__/post-tool-use/auto-lint.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash __HAPAI_HOOKS__/post-tool-use/auto-checkpoint.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash __HAPAI_HOOKS__/post-tool-use/audit-trail.sh",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash __HAPAI_HOOKS__/post-tool-use/pr-review-trigger.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash __HAPAI_HOOKS__/stop/squash-checkpoints.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash __HAPAI_HOOKS__/stop/require-tests.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash __HAPAI_HOOKS__/stop/cost-tracker.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash __HAPAI_HOOKS__/user-prompt-submit/warn-production.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash __HAPAI_HOOKS__/session-start/load-context.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash __HAPAI_HOOKS__/pre-compact/backup-transcript.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash __HAPAI_HOOKS__/notification/sound-alert.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash __HAPAI_HOOKS__/permission-request/auto-allow-readonly.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
