#!/usr/bin/env bash
# hapai — CLI for managing AI coding guardrails
# Usage: hapai <command> [options]
#
# Commands:
#   install     Install hooks globally or per-project
#   uninstall   Remove hooks
#   validate    Verify installation integrity
#   kill        Emergency kill switch — disable all hooks instantly
#   revive      Restore hooks after kill
#   status      Show active hooks, risk tier, last execution
#   audit       Show recent audit log entries
#   sync        Sync audit logs to Cloud Storage (requires GCP setup)
#   export      Export guardrails for other tools (claude, cursor, copilot)

set -euo pipefail

HAPAI_VERSION="1.0.0"
HAPAI_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
HAPAI_HOME="${HAPAI_HOME:-$HOME/.hapai}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# ─── Helpers ────────────────────────────────────────────────────────────────

log_info()  { echo -e "${CYAN}ℹ${NC} $*"; }
log_ok()    { echo -e "${GREEN}✓${NC} $*"; }
log_warn()  { echo -e "${YELLOW}⚠${NC} $*"; }
log_error() { echo -e "${RED}✗${NC} $*"; }

ensure_jq() {
  if ! command -v jq &>/dev/null; then
    log_error "jq is required but not installed. Install with: brew install jq"
    exit 1
  fi

  # Verify jq version is 1.6 or higher (required for walk/1 function)
  local jq_version
  jq_version="$(jq --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+' | head -1)"
  if [[ -z "$jq_version" ]]; then
    log_warn "Could not determine jq version. Minimum 1.6 required. Continuing anyway..."
    return 0
  fi

  # Simple version check: 1.6 or higher
  local major minor
  major="${jq_version%%.*}"
  minor="${jq_version##*.}"
  if [[ "$major" -lt 1 ]] || { [[ "$major" -eq 1 ]] && [[ "$minor" -lt 6 ]]; }; then
    log_error "jq version $jq_version found, but 1.6+ is required. Upgrade with: brew upgrade jq"
    exit 1
  fi
}

# ─── INSTALL ────────────────────────────────────────────────────────────────

cmd_install() {
  ensure_jq
  local mode="project"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --global|-g) mode="global"; shift ;;
      --project|-p) mode="project"; shift ;;
      *) shift ;;
    esac
  done

  local hooks_dest settings_file claude_md_file

  if [[ "$mode" == "global" ]]; then
    hooks_dest="$HAPAI_HOME/hooks"
    settings_file="$HOME/.claude/settings.json"
    claude_md_file="$HOME/.claude/CLAUDE.md"
    log_info "Installing hapai globally..."
  else
    hooks_dest=".claude/hooks/hapai"
    settings_file=".claude/settings.json"
    claude_md_file="CLAUDE.md"
    log_info "Installing hapai for current project..."
  fi

  # 1. Copy hooks
  mkdir -p "$hooks_dest" || {
    log_error "Cannot create directory: $hooks_dest (check permissions)"
    exit 1
  }

  if ! cp -r "$HAPAI_ROOT/hooks/"* "$hooks_dest/" 2>/dev/null; then
    log_error "Failed to copy hooks to $hooks_dest"
    exit 1
  fi

  # chmod +x on all .sh files (find instead of globstar which needs shopt -s globstar)
  find "$hooks_dest" -name "*.sh" -type f -exec chmod +x {} + 2>/dev/null || true
  log_ok "Hooks copied to $hooks_dest"

  # 2. Backup settings.json
  if [[ -f "$settings_file" ]]; then
    local backup="${settings_file}.bak.$(date +%Y%m%d%H%M%S)"
    cp "$settings_file" "$backup"
    log_ok "Backup: $backup"
  fi

  # 3. Merge hooks into settings.json
  local hooks_abs_path
  hooks_abs_path="$(cd "$hooks_dest" 2>/dev/null && pwd)"

  # Generate settings from template with resolved paths
  local template="$HAPAI_ROOT/templates/settings.hooks.json"
  local resolved
  # Use jq for safe path substitution (avoids sed delimiter collision if path contains |)
  resolved="$(jq --arg path "$hooks_abs_path" 'walk(if type == "string" then gsub("__HAPAI_HOOKS__"; $path) else . end)' "$template")"

  if [[ -f "$settings_file" ]]; then
    # Deep merge: existing settings + hapai hooks
    local existing
    existing="$(cat "$settings_file")"

    # Merge hooks arrays (append hapai hooks to existing)
    local merged
    merged="$(echo "$existing" | jq --argjson hapai "$resolved" '
      . as $base |
      $hapai.hooks as $new_hooks |
      ($base.hooks // {}) as $existing_hooks |
      # For each hook event, concatenate arrays (dedup by command)
      reduce ($new_hooks | keys[]) as $event (
        $base;
        .hooks[$event] = (
          ($existing_hooks[$event] // []) +
          ($new_hooks[$event] // [])
          | unique_by(.hooks[0].command // .command // .)
        )
      )
    ' 2>/dev/null)" || {
      # If merge fails, just add hooks key
      merged="$(echo "$existing" | jq --argjson hapai "$resolved" '. + {hooks: $hapai.hooks}' 2>/dev/null)" || merged="$resolved"
    }

    echo "$merged" | jq '.' > "$settings_file"
  else
    mkdir -p "$(dirname "$settings_file")"
    echo "$resolved" | jq '.' > "$settings_file"
  fi
  log_ok "Hooks merged into $settings_file"

  # 4. Copy default config
  if [[ "$mode" == "global" ]]; then
    if [[ ! -f "$HAPAI_HOME/hapai.yaml" ]]; then
      cp "$HAPAI_ROOT/hapai.defaults.yaml" "$HAPAI_HOME/hapai.yaml"
      log_ok "Default config: $HAPAI_HOME/hapai.yaml"
    else
      log_info "Config already exists: $HAPAI_HOME/hapai.yaml (skipped)"
    fi
  else
    if [[ ! -f "hapai.yaml" ]]; then
      cp "$HAPAI_ROOT/hapai.defaults.yaml" "hapai.yaml"
      log_ok "Default config: hapai.yaml"
    else
      log_info "Config already exists: hapai.yaml (skipped)"
    fi
  fi

  # 5. CLAUDE.md injection
  if [[ -f "$claude_md_file" ]]; then
    local inject_content
    inject_content="$(cat "$HAPAI_ROOT/templates/claude.md.inject")"

    if grep -q "<!-- hapai:start -->" "$claude_md_file" 2>/dev/null; then
      # Upsert: replace existing block (validate end marker exists for safety)
      if grep -q "<!-- hapai:end -->" "$claude_md_file" 2>/dev/null; then
        local temp_file
        temp_file="$(mktemp)"
        awk '
          /<!-- hapai:start -->/ { skip=1; next }
          /<!-- hapai:end -->/ { skip=0; next }
          !skip { print }
        ' "$claude_md_file" > "$temp_file"
        echo "" >> "$temp_file"
        echo "$inject_content" >> "$temp_file"
        mv "$temp_file" "$claude_md_file"
      else
        log_warn "CLAUDE.md has hapai:start but missing hapai:end — skipping injection"
      fi
      log_ok "CLAUDE.md updated (hapai block replaced)"
    else
      # Append
      echo "" >> "$claude_md_file"
      echo "$inject_content" >> "$claude_md_file"
      log_ok "CLAUDE.md updated (hapai block appended)"
    fi
  else
    log_warn "No CLAUDE.md found at $claude_md_file (skipped injection)"
  fi

  # 6. Initialize state directories
  mkdir -p "$HAPAI_HOME" "$HAPAI_HOME/state" 2>/dev/null || true
  touch "$HAPAI_HOME/audit.jsonl" 2>/dev/null || true
  log_ok "State initialized: $HAPAI_HOME"

  echo ""
  log_ok "${BOLD}hapai installed successfully!${NC}"
  echo "  Run 'hapai validate' to verify installation"
  echo "  Run 'hapai status' to see active hooks"
}

# ─── UNINSTALL ──────────────────────────────────────────────────────────────

cmd_uninstall() {
  ensure_jq
  local mode="project"
  [[ "${1:-}" == "--global" || "${1:-}" == "-g" ]] && mode="global"

  local settings_file
  if [[ "$mode" == "global" ]]; then
    settings_file="$HOME/.claude/settings.json"
    log_info "Uninstalling hapai globally..."

    # Remove hooks directory
    rm -rf "$HAPAI_HOME/hooks" 2>/dev/null || true
    log_ok "Removed $HAPAI_HOME/hooks"
  else
    settings_file=".claude/settings.json"
    log_info "Uninstalling hapai from current project..."

    rm -rf ".claude/hooks/hapai" 2>/dev/null || true
    log_ok "Removed .claude/hooks/hapai"
  fi

  # Remove hapai hooks from settings.json
  if [[ -f "$settings_file" ]]; then
    local cleaned
    cleaned="$(jq '
      if .hooks then
        .hooks |= with_entries(
          .value |= map(
            select(
              (.hooks // [{}])[0].command // .command // "" |
              contains("hapai") | not
            )
          ) | select(length > 0)
        ) |
        if .hooks == {} then del(.hooks) else . end
      else . end
    ' "$settings_file" 2>/dev/null)" || cleaned=""

    if [[ -n "$cleaned" ]]; then
      echo "$cleaned" | jq '.' > "$settings_file"
      log_ok "Hooks removed from $settings_file"
    fi
  fi

  # Remove CLAUDE.md injection
  for md_file in "$HOME/.claude/CLAUDE.md" "CLAUDE.md"; do
    if [[ -f "$md_file" ]] && grep -q "<!-- hapai:start -->" "$md_file" 2>/dev/null; then
      # Validate both markers exist before using awk
      if grep -q "<!-- hapai:end -->" "$md_file" 2>/dev/null; then
        local temp_file
        temp_file="$(mktemp)"
        awk '
          /<!-- hapai:start -->/ { skip=1; next }
          /<!-- hapai:end -->/ { skip=0; next }
          !skip { print }
        ' "$md_file" > "$temp_file"
        mv "$temp_file" "$md_file"
        log_ok "Removed hapai block from $md_file"
      else
        log_warn "$md_file has hapai:start but missing hapai:end — skipping"
      fi
    fi
  done

  log_ok "${BOLD}hapai uninstalled${NC}"
}

# ─── VALIDATE ───────────────────────────────────────────────────────────────

cmd_validate() {
  ensure_jq
  local errors=0
  local warnings=0

  echo -e "${BOLD}hapai validate${NC} v${HAPAI_VERSION}"
  echo "─────────────────────────────────"

  # Check settings.json for hooks
  local found_settings=0
  for settings_file in "$HOME/.claude/settings.json" ".claude/settings.json" ".claude/settings.local.json"; do
    if [[ -f "$settings_file" ]]; then
      if grep -q "hapai" "$settings_file" 2>/dev/null; then
        log_ok "Hooks registered in $settings_file"
        found_settings=1
      fi
    fi
  done
  if [[ $found_settings -eq 0 ]]; then
    log_error "No hapai hooks found in any settings.json"
    errors=$((errors + 1))
  fi

  # Check hook scripts exist and are executable
  local hook_dirs=("$HAPAI_HOME/hooks" ".claude/hooks/hapai")
  local found_hooks=0
  for hook_dir in "${hook_dirs[@]}"; do
    if [[ -d "$hook_dir" ]]; then
      found_hooks=1
      local total=0
      local executable=0
      while IFS= read -r script; do
        total=$((total + 1))
        if [[ -x "$script" ]]; then
          executable=$((executable + 1))
        else
          log_warn "Not executable: $script"
          warnings=$((warnings + 1))
        fi
      done <<< "$(find "$hook_dir" -name "*.sh" -type f 2>/dev/null)"

      log_ok "Hook scripts: $executable/$total executable in $hook_dir"
    fi
  done
  if [[ $found_hooks -eq 0 ]]; then
    log_error "No hook directory found"
    errors=$((errors + 1))
  fi

  # Check hapai.yaml exists
  if [[ -f "hapai.yaml" ]]; then
    log_ok "Project config: hapai.yaml"
  elif [[ -f "$HAPAI_HOME/hapai.yaml" ]]; then
    log_ok "Global config: $HAPAI_HOME/hapai.yaml"
  else
    log_warn "No hapai.yaml found (using defaults)"
    warnings=$((warnings + 1))
  fi

  # Check jq
  if command -v jq &>/dev/null; then
    log_ok "jq: $(jq --version 2>/dev/null || echo 'installed')"
  else
    log_error "jq not installed (required)"
    errors=$((errors + 1))
  fi

  # Check audit log
  if [[ -f "$HAPAI_HOME/audit.jsonl" ]]; then
    local lines
    lines="$(wc -l < "$HAPAI_HOME/audit.jsonl" | tr -d ' ')"
    log_ok "Audit log: $lines entries"
  else
    log_info "Audit log: not initialized yet"
  fi

  # Check state directory
  if [[ -d "$HAPAI_HOME/state" ]]; then
    local state_count
    state_count="$(find "$HAPAI_HOME/state" -type f 2>/dev/null | wc -l | tr -d ' ')"
    log_ok "State: $state_count entries"
  fi

  echo "─────────────────────────────────"
  if [[ $errors -gt 0 ]]; then
    log_error "${BOLD}Validation failed: $errors errors, $warnings warnings${NC}"
    exit 1
  elif [[ $warnings -gt 0 ]]; then
    log_warn "${BOLD}Validation passed with $warnings warnings${NC}"
  else
    log_ok "${BOLD}All checks passed${NC}"
  fi
}

# ─── KILL ───────────────────────────────────────────────────────────────────

cmd_kill() {
  echo -e "${RED}${BOLD}hapai KILL SWITCH${NC}"

  for settings_file in "$HOME/.claude/settings.json" ".claude/settings.json"; do
    if [[ -f "$settings_file" ]] && grep -q "hapai" "$settings_file" 2>/dev/null; then
      mv "$settings_file" "${settings_file}.hapai-killed"
      log_ok "Disabled: $settings_file → ${settings_file}.hapai-killed"
    fi
  done

  # Mark state
  mkdir -p "$HAPAI_HOME" 2>/dev/null || true
  date -u +"%Y-%m-%dT%H:%M:%SZ" > "$HAPAI_HOME/killed_at"

  log_ok "${BOLD}All hapai hooks disabled. Run 'hapai revive' to restore.${NC}"
}

# ─── REVIVE ─────────────────────────────────────────────────────────────────

cmd_revive() {
  echo -e "${GREEN}${BOLD}hapai REVIVE${NC}"

  for killed_file in "$HOME/.claude/settings.json.hapai-killed" ".claude/settings.json.hapai-killed"; do
    if [[ -f "$killed_file" ]]; then
      local target="${killed_file%.hapai-killed}"
      if [[ -f "$target" ]]; then
        # Target was recreated after kill — merge hapai hooks back in while preserving user additions
        local new_backup="${target}.pre-revive.$(date +%Y%m%d%H%M%S)"
        cp "$target" "$new_backup"
        log_warn "Existing $target backed up to $new_backup."

        # Merge: restore hapai hooks from killed_file, preserve non-hapai hooks from target
        local merged
        merged="$(jq -s '
          .[0] as $killed |
          .[1] as $current |
          ($current.commands // [] | map(select(.command | contains("hapai") | not))) as $non_hapai |
          ($killed.commands // [] | map(select(.command | contains("hapai")))) as $hapai |
          ($current.comments // []) as $comments |
          {commands: ($hapai + $non_hapai), comments: $comments}
        ' "$killed_file" "$target" 2>/dev/null)"

        if [[ -n "$merged" ]]; then
          echo "$merged" > "$target" 2>/dev/null || {
            log_error "Failed to write merged settings. Kept backup at $new_backup."
            continue
          }
          log_ok "Restored hapai hooks. Preserved other tool hooks. Backup: $new_backup"
        else
          log_error "Failed to merge. Keeping backup at $new_backup. Restore manually if needed."
          continue
        fi
      else
        # Target doesn't exist, safe to just restore
        mv "$killed_file" "$target"
        log_ok "Restored: $target"
      fi
    fi
  done

  rm -f "$HAPAI_HOME/killed_at" 2>/dev/null || true
  log_ok "${BOLD}All hapai hooks restored.${NC}"
}

# ─── STATUS ─────────────────────────────────────────────────────────────────

cmd_status() {
  echo -e "${BOLD}hapai status${NC} v${HAPAI_VERSION}"
  echo "─────────────────────────────────"

  # Check if killed
  if [[ -f "$HAPAI_HOME/killed_at" ]]; then
    local killed_at
    killed_at="$(cat "$HAPAI_HOME/killed_at" 2>/dev/null)"
    log_error "${BOLD}KILLED${NC} since $killed_at — run 'hapai revive' to restore"
    return
  fi

  # Active hooks
  local hook_count=0
  for hook_dir in "$HAPAI_HOME/hooks" ".claude/hooks/hapai"; do
    if [[ -d "$hook_dir" ]]; then
      local count
      count="$(find "$hook_dir" -name "*.sh" -not -name "_lib.sh" -type f 2>/dev/null | wc -l | tr -d ' ')"
      hook_count=$((hook_count + count))
    fi
  done
  log_info "Active hooks: $hook_count"

  # Last audit entries
  if [[ -f "$HAPAI_HOME/audit.jsonl" ]]; then
    local total deny_count
    total="$(wc -l < "$HAPAI_HOME/audit.jsonl" | tr -d ' ')"
    deny_count="$(grep -c '"result":"deny"' "$HAPAI_HOME/audit.jsonl" 2>/dev/null || echo "0")"
    log_info "Audit log: $total events ($deny_count denials)"

    echo ""
    echo -e "${BOLD}Last 5 events:${NC}"
    tail -5 "$HAPAI_HOME/audit.jsonl" 2>/dev/null | while IFS= read -r line; do
      local ts hook result reason
      ts="$(echo "$line" | jq -r '.ts // "?"' 2>/dev/null)"
      hook="$(echo "$line" | jq -r '.hook // "?"' 2>/dev/null)"
      result="$(echo "$line" | jq -r '.result // "?"' 2>/dev/null)"
      reason="$(echo "$line" | jq -r '.reason // ""' 2>/dev/null | head -c 60)"

      case "$result" in
        deny)  echo -e "  ${RED}●${NC} $ts $hook → $result ${reason:+($reason)}" ;;
        warn)  echo -e "  ${YELLOW}●${NC} $ts $hook → $result ${reason:+($reason)}" ;;
        *)     echo -e "  ${GREEN}●${NC} $ts $hook → $result" ;;
      esac
    done
  else
    log_info "Audit log: empty"
  fi

  # State counters (deny_count + warn_count)
  echo ""
  echo -e "${BOLD}Hook counters:${NC}"
  local found_counters=0
  for state_file in "$HAPAI_HOME/state/"*_count; do
    [[ -f "$state_file" ]] || continue
    local name count suffix
    name="$(basename "$state_file")"
    count="$(cat "$state_file" 2>/dev/null || echo "0")"
    [[ "$count" -gt 0 ]] || continue
    found_counters=1
    # Format: guard-branch.deny_count → guard-branch: 5 blocks
    #         guard-blast-radius.warn_count → guard-blast-radius: 3 warnings
    if [[ "$name" == *.deny_count ]]; then
      echo -e "  ${RED}${name%.deny_count}${NC}: $count blocks"
    elif [[ "$name" == *.warn_count ]]; then
      echo -e "  ${YELLOW}${name%.warn_count}${NC}: $count warnings"
    fi
  done
  [[ $found_counters -eq 0 ]] && echo "  (none yet)"
}

# ─── AUDIT ──────────────────────────────────────────────────────────────────

cmd_audit() {
  local lines="${1:-20}"
  local audit_file="$HAPAI_HOME/audit.jsonl"

  # Validate lines is a positive integer (defense against invalid flag injection)
  if [[ ! "$lines" =~ ^[0-9]+$ ]] || [[ "$lines" -eq 0 ]]; then
    lines=20
  fi

  if [[ ! -f "$audit_file" ]]; then
    log_info "No audit log yet."
    return
  fi

  echo -e "${BOLD}hapai audit${NC} (last $lines entries)"
  echo "─────────────────────────────────"

  tail -"$lines" "$audit_file" | while IFS= read -r line; do
    local ts event hook tool result reason
    ts="$(echo "$line" | jq -r '.ts // "?"' 2>/dev/null)"
    event="$(echo "$line" | jq -r '.event // "?"' 2>/dev/null)"
    hook="$(echo "$line" | jq -r '.hook // "?"' 2>/dev/null)"
    tool="$(echo "$line" | jq -r '.tool // "?"' 2>/dev/null)"
    result="$(echo "$line" | jq -r '.result // "?"' 2>/dev/null)"
    reason="$(echo "$line" | jq -r '.reason // ""' 2>/dev/null | head -c 80)"

    local color="$GREEN"
    [[ "$result" == "deny" ]] && color="$RED"
    [[ "$result" == "warn" ]] && color="$YELLOW"

    printf "  ${color}%-6s${NC} %s %-20s %-12s %s\n" "$result" "$ts" "$hook" "$tool" "$reason"
  done
}

# ─── BLOCKLIST ──────────────────────────────────────────────────────────────

# Parse duration string to seconds: "30m" → 1800, "2h" → 7200, "1d" → 86400
# KEEP IN SYNC with hooks/_lib.sh:_parse_duration (identical copy for CLI context)
_parse_cli_duration() {
  local spec="$1"
  local num="${spec%[mhds]}"
  local unit="${spec: -1}"
  [[ ! "$num" =~ ^[0-9]+$ ]] && echo "1800" && return
  case "$unit" in
    m) echo $((num * 60)) ;;
    h) echo $((num * 3600)) ;;
    d) echo $((num * 86400)) ;;
    s) echo "$num" ;;
    *) echo $((num * 60)) ;;
  esac
}

_timestamp_future_cli() {
  local seconds="$1"
  local epoch_now epoch_then
  epoch_now="$(date -u +%s)"
  epoch_then=$((epoch_now + seconds))
  if date -d "@${epoch_then}" &>/dev/null 2>&1; then
    date -u -d "@${epoch_then}" +"%Y-%m-%dT%H:%M:%SZ"
  else
    date -u -r "$epoch_then" +"%Y-%m-%dT%H:%M:%SZ"
  fi
}

cmd_block() {
  ensure_jq
  local pattern="" type="general" duration="30m" reason=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --type|-t)   shift; type="${1:-general}" ;;
      --for|-f)    shift; duration="${1:-30m}" ;;
      --reason|-r) shift; reason="${1:-}" ;;
      *)           [[ -z "$pattern" ]] && pattern="$1" ;;
    esac
    shift
  done

  if [[ -z "$pattern" ]]; then
    log_error "Usage: hapai block <pattern> [--type branch|file|command] [--for 30m|2h|1d] [--reason \"text\"]"
    exit 1
  fi

  local blocklist_file="${HAPAI_HOME}/state/blocklist.json"
  local duration_seconds expires_at

  duration_seconds="$(_parse_cli_duration "$duration")"
  expires_at="$(_timestamp_future_cli "$duration_seconds")"

  mkdir -p "${HAPAI_HOME}/state" 2>/dev/null || true
  [[ ! -f "$blocklist_file" ]] && echo "[]" > "$blocklist_file"

  local updated
  updated="$(jq \
    --arg pat "$pattern" --arg typ "$type" \
    --arg exp "$expires_at" --arg rsn "${reason:0:200}" \
    '[.[] | select(.pattern != $pat or .type != $typ)] +
     [{pattern: $pat, type: $typ, expires_at: $exp, reason: $rsn}]' \
    "$blocklist_file")"
  echo "$updated" > "$blocklist_file"

  log_ok "Blocked: ${BOLD}${pattern}${NC} (type: $type) until $expires_at"
  [[ -n "$reason" ]] && log_info "Reason: $reason"
}

cmd_unblock() {
  ensure_jq
  local pattern="${1:-}"

  if [[ -z "$pattern" ]]; then
    log_error "Usage: hapai unblock <pattern>"
    exit 1
  fi

  local blocklist_file="${HAPAI_HOME}/state/blocklist.json"
  [[ ! -f "$blocklist_file" ]] && log_info "No active blocks." && return

  local updated
  updated="$(jq --arg pat "$pattern" '[.[] | select(.pattern != $pat)]' "$blocklist_file")"
  echo "$updated" > "$blocklist_file"
  log_ok "Unblocked: $pattern"
}

cmd_blocklist() {
  ensure_jq
  local blocklist_file="${HAPAI_HOME}/state/blocklist.json"

  if [[ ! -f "$blocklist_file" ]]; then
    log_info "No active blocks."
    return
  fi

  # Clean expired entries first
  local now_epoch
  now_epoch="$(date -u +%s)"
  local cleaned
  cleaned="$(jq --argjson now "$now_epoch" \
    '[.[] | select((.expires_at | strptime("%Y-%m-%dT%H:%M:%SZ") | mktime) > $now)]' \
    "$blocklist_file" 2>/dev/null)" || cleaned="[]"
  echo "$cleaned" > "$blocklist_file"

  local count
  count="$(echo "$cleaned" | jq 'length')"

  if [[ "$count" -eq 0 ]]; then
    log_info "No active blocks."
    return
  fi

  echo -e "${BOLD}hapai blocklist${NC} ($count active)"
  echo "─────────────────────────────────"

  echo "$cleaned" | jq -r '.[] | [.pattern, .type, .expires_at, .reason] | @tsv' | \
  while IFS=$'\t' read -r pat typ exp rsn; do
    printf "  ${YELLOW}●${NC} %-30s %-10s expires: %s" "$pat" "$typ" "$exp"
    [[ -n "$rsn" ]] && printf "  (%s)" "$rsn"
    echo ""
  done
}

cmd_list_hooks() {
  echo -e "${BOLD}hapai list-hooks${NC}"
  echo "─────────────────────────────────"

  local found=0
  for hook_dir in "${HAPAI_HOME}/hooks" ".claude/hooks/hapai"; do
    [[ ! -d "$hook_dir" ]] && continue
    found=1
    echo -e "${CYAN}${hook_dir}${NC}"
    find "$hook_dir" -name "*.sh" -not -name "_lib.sh" -type f | sort | while read -r f; do
      local name
      name="$(basename "$f" .sh)"
      local label="built-in"
      echo -e "  ${GREEN}✓${NC} $name  ${YELLOW}[$label]${NC}"
    done
  done

  [[ $found -eq 0 ]] && log_warn "No hooks installed. Run 'hapai install' first."
}

# ─── SYNC (Cloud Logging) ───────────────────────────────────────────────────

cmd_sync() {
  ensure_jq

  # Parse arguments
  local dry_run=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run) dry_run=true; shift ;;
      *) shift ;;
    esac
  done

  # Load config
  source "$HAPAI_ROOT/hooks/_lib.sh" || {
    log_error "Failed to load config library"
    exit 1
  }

  # Check if GCP is configured
  local gcp_enabled project_id bucket region
  gcp_enabled="$(config_get "gcp.enabled" "false")"
  if [[ "$gcp_enabled" != "true" ]]; then
    log_error "GCP sync is not enabled. Set 'gcp.enabled: true' in hapai.yaml"
    exit 1
  fi

  project_id="$(config_get "gcp.project_id" "")"
  bucket="$(config_get "gcp.bucket" "")"
  region="$(config_get "gcp.region" "us-east1")"

  if [[ -z "$project_id" ]] || [[ -z "$bucket" ]]; then
    log_error "Missing GCP config: project_id and bucket are required"
    log_info "Set these in hapai.yaml:"
    log_info "  gcp:"
    log_info "    enabled: true"
    log_info "    project_id: my-gcp-project"
    log_info "    bucket: hapai-audit-username"
    exit 1
  fi

  # Check credentials: support both OIDC (GitHub Actions) and service account keys (local)
  local use_oidc=false

  local adc_file="${HOME}/.config/gcloud/application_default_credentials.json"

  if [[ -n "${GOOGLE_IDENTITY_TOKEN:-}" ]]; then
    # OIDC mode (GitHub Actions Workload Identity Federation)
    use_oidc=true
    log_info "Using OIDC (Workload Identity Federation)"
  elif [[ -n "${GOOGLE_APPLICATION_CREDENTIALS:-}" ]]; then
    # Service account key mode (local development)
    if [[ ! -f "$GOOGLE_APPLICATION_CREDENTIALS" ]]; then
      log_error "GOOGLE_APPLICATION_CREDENTIALS file not found: $GOOGLE_APPLICATION_CREDENTIALS"
      exit 1
    fi
    log_info "Using service account key: $GOOGLE_APPLICATION_CREDENTIALS"
  elif [[ -f "$adc_file" ]]; then
    # Application Default Credentials (gcloud auth application-default login)
    export GOOGLE_APPLICATION_CREDENTIALS="$adc_file"
    log_info "Using Application Default Credentials: $adc_file"
  else
    log_error "No GCP credentials found. Choose one:"
    log_info "  Application Default Credentials (recommended):"
    log_info "    gcloud auth application-default login"
    log_info "  Service account key:"
    log_info "    export GOOGLE_APPLICATION_CREDENTIALS=~/.config/gcp-sa-key.json"
    log_info "  GitHub Actions (OIDC):"
    log_info "    Use 'google-github-actions/auth@v1' with Workload Identity"
    exit 1
  fi

  # Check source file
  local audit_file="$HAPAI_HOME/audit.jsonl"
  if [[ ! -f "$audit_file" ]]; then
    log_warn "No audit log found at $audit_file"
    return 0
  fi

  # Prepare destination path: gs://bucket/YYYY-MM/DD.jsonl
  local now date_part day_part gcs_path
  now="$(date -u +%Y-%m-%d)"
  date_part="${now:0:7}"  # YYYY-MM
  day_part="${now:8:2}"   # DD
  gcs_path="gs://${bucket}/${date_part}/${day_part}.jsonl"

  log_info "Syncing audit log to Cloud Storage..."
  log_info "Source: $audit_file"
  log_info "Destination: $gcs_path"

  if [[ "$dry_run" == "true" ]]; then
    log_info "[DRY-RUN] Would sync to $gcs_path"
    return 0
  fi

  # Check if gsutil is available
  if ! command -v gsutil &>/dev/null; then
    log_error "gsutil is required but not installed"
    log_info "Install Google Cloud SDK: https://cloud.google.com/sdk/docs/install"
    exit 1
  fi

  # Upload to Cloud Storage
  if gsutil -m cp "$audit_file" "$gcs_path" 2>&1; then
    log_ok "Sync completed successfully"
    log_info "Uploaded to $gcs_path"
  else
    log_error "Failed to sync audit log to Cloud Storage"
    exit 1
  fi

  # Load into BigQuery
  if command -v bq &>/dev/null; then
    local bq_table="${project_id}:hapai_dataset.events"
    log_info "Loading into BigQuery: $bq_table"
    if bq load \
        --source_format=NEWLINE_DELIMITED_JSON \
        --ignore_unknown_values \
        --replace=false \
        "$bq_table" \
        "$gcs_path" 2>&1; then
      log_ok "BigQuery load completed"
    else
      log_warn "BigQuery load failed — data is still in Cloud Storage at $gcs_path"
    fi
  else
    log_warn "bq CLI not found — skipping BigQuery load (data uploaded to GCS)"
    log_info "To load manually: bq load --source_format=NEWLINE_DELIMITED_JSON ${project_id}:hapai_dataset.events $gcs_path"
  fi
}

# ─── EXPORT ─────────────────────────────────────────────────────────────────

SUPPORTED_TARGETS="claude cursor copilot windsurf devin trae antigravity universal"

cmd_export() {
  local target="${1:-claude}"

  case "$target" in
    --target)
      shift
      target="${1:-claude}"
      ;;
    --all)
      target="all"
      ;;
  esac

  if [[ "$target" == "all" ]]; then
    _export_all
    return
  fi

  case "$target" in
    claude)
      log_info "Claude Code hooks are managed via 'hapai install --global' or 'hapai install --project'."
      log_info "Verifying current installation:"
      echo ""
      cmd_validate
      echo ""
      log_info "To reinstall/update: hapai install --global"
      log_info "Config file: ${HAPAI_HOME}/hapai.yaml (global) or hapai.yaml (project)"
      ;;
    cursor|copilot|windsurf|devin|trae|antigravity|universal)
      _run_exporter "$target"
      ;;
    *)
      log_error "Unknown target: $target"
      log_info "Supported: $SUPPORTED_TARGETS"
      exit 1
      ;;
  esac
}

_run_exporter() {
  local target="$1"
  local exporter="$HAPAI_ROOT/exporters/export-${target}.sh"

  if [[ ! -x "$exporter" ]]; then
    log_error "Exporter not found: $exporter"
    exit 1
  fi

  local output
  output="$(bash "$exporter" 2>&1)"
  log_ok "Exported to $output"
}

_export_all() {
  log_info "Exporting guardrails to all supported tools..."
  echo ""

  local count=0
  for target in cursor copilot windsurf devin trae antigravity; do
    local exporter="$HAPAI_ROOT/exporters/export-${target}.sh"
    if [[ -x "$exporter" ]]; then
      local output
      output="$(bash "$exporter" 2>&1)"
      log_ok "$target → $output"
      count=$((count + 1))
    fi
  done

  echo ""
  log_ok "${BOLD}Exported to $count tools${NC}"
  log_info "Claude Code uses hooks (run 'hapai install' instead)"
}

# ─── MAIN ───────────────────────────────────────────────────────────────────

cmd_help() {
  cat << EOF
${BOLD}hapai${NC} v${HAPAI_VERSION} — AI coding guardrails

${BOLD}Usage:${NC}
  hapai <command> [options]

${BOLD}Commands:${NC}
  install [--global|--project]   Install hooks
  uninstall [--global]           Remove hooks
  validate                       Verify installation
  kill                           Emergency kill switch
  revive                         Restore after kill
  status                         Show active state
  audit [N]                      Show last N audit entries (default: 20)
  export --target <target>       Export guardrails for a specific tool
  export --all                   Export to ALL supported tools at once
  block <pattern> [--type branch|file|command] [--for 30m|2h|1d] [--reason "text"]
  unblock <pattern>              Remove from temporary blocklist
  blocklist                      Show active blocks with expiry times
  list-hooks                     List installed hooks (built-in + community)

${BOLD}Supported export targets:${NC}
  claude, cursor, copilot, windsurf, devin, trae, antigravity, universal

${BOLD}Examples:${NC}
  hapai install --global              Install for all projects
  hapai install --project             Install for current project
  hapai validate                      Check everything is working
  hapai kill                          Panic button — disable all hooks
  hapai block main --type branch --for 2h --reason "CI broken"
  hapai block ".env.prod" --type file --for 1d
  hapai blocklist                     Show all active blocks
  hapai unblock main
  hapai list-hooks                    Show installed hooks
  hapai sync                          Sync audit logs to Cloud Storage
  hapai sync --dry-run                Preview sync without uploading
  hapai export --target cursor        Generate .cursor/rules/hapai.mdc
  hapai export --all                  Export to all supported tools

${BOLD}Docs:${NC} https://github.com/renatobardi/hapai
EOF
}

case "${1:-help}" in
  install)      shift; cmd_install "$@" ;;
  uninstall)    shift; cmd_uninstall "$@" ;;
  validate)     cmd_validate ;;
  kill)         cmd_kill ;;
  revive)       cmd_revive ;;
  status)       cmd_status ;;
  audit)        shift; cmd_audit "${1:-20}" ;;
  sync)         shift; cmd_sync "$@" ;;
  export)       shift; cmd_export "$@" ;;
  block)        shift; cmd_block "$@" ;;
  unblock)      shift; cmd_unblock "$@" ;;
  blocklist)    cmd_blocklist ;;
  list-hooks)   cmd_list_hooks ;;
  help|--help|-h) cmd_help ;;
  version|--version|-v) echo "hapai v${HAPAI_VERSION}" ;;
  *)
    log_error "Unknown command: $1"
    cmd_help
    exit 1
    ;;
esac
